<!DOCTYPE html><html lang="pt-BR"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Teste de Motivadores - Edson Lima</title><link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet"><style>:root{--primary:#0a192f;--accent:#3b82f6;--text:#333;--bg:#f8fafc;--white:#ffffff}body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);line-height:1.6;margin:0;padding:20px}h1,h2{font-family:'Playfair Display',serif;color:var(--primary)}.container{max-width:800px;margin:0 auto;background:var(--white);padding:40px;border-radius:12px;box-shadow:0 10px 25px rgba(0,0,0,0.1)}.question{margin-bottom:25px;padding:15px;border-bottom:1px solid #eee}.btn{background:var(--primary);color:white;padding:12px 24px;border:none;border-radius:6px;cursor:pointer;font-weight:bold;margin-top:20px}.hidden{display:none}#report{margin-top:30px;padding:20px;border:2px solid var(--primary);border-radius:8px}</style></head><body><div class="container" id="app"><h1>Teste de Motivadores AACP</h1><p>Responda com base em comportamentos reais, não ideais.</p><div id="quiz"></div><button class="btn" onclick="calculateResults()">Gerar Relatório</button></div><div id="report" class="container hidden"><h2>Seu Perfil de Liderança</h2><div id="resultContent"></div><button class="btn" onclick="copyToClipboard()">Copiar para Mentor</button><button class="btn" style="background:var(--accent)" onclick="sendEmail()">Enviar por E-mail</button></div><script>const questions=[{q:"Prefiro confrontar um problema imediatamente a esperar que ele se resolva sozinho.",cat:"Desafiante"},{q:"Sinto satisfação em garantir que todos na equipe estejam bem emocionalmente.",cat:"Cuidador"},{q:"Busco constantemente formas de otimizar processos existentes.",cat:"Analítico"},{q:"Gosto de liderar projetos que trazem visibilidade para a equipe.",cat:"Realizador"},{q:"Minha prioridade é manter a harmonia, mesmo que isso atrase uma decisão.",cat:"Cuidador"},{q:"Sinto-me desconfortável quando metas não são atingidas com precisão.",cat:"Analítico"},{q:"Gosto de assumir riscos calculados em situações de incerteza.",cat:"Desafiante"},{q:"Prefiro ser reconhecido pelos resultados do que pelo processo.",cat:"Realizador"},/* ... (Adicionar até 35 perguntas) */];let answers={};function init(){const qDiv=document.getElementById('quiz');questions.forEach((item,i)=>{qDiv.innerHTML+=`<div class="question"><p>${i+1}. ${item.q}</p><input type="range" min="1" max="5" value="3" onchange="answers[${i}]=this.value"></div>`})}function calculateResults(){const scores={Desafiante:0,Cuidador:0,Analítico:0,Realizador:0};questions.forEach((item,i)=>{scores[item.cat]+=parseInt(answers[i]||3)});let report=`<p>Análise AACP:</p><ul>`;for(let cat in scores){report+=`<li>${cat}: ${scores[cat]}</li>`}if(scores.Desafiante>15 && scores.Cuidador>15) report+="<p><strong>Atenção:</strong> Identificamos um ponto cego. Você busca resultados agressivos, mas sua necessidade de cuidado pode gerar hesitação em decisões difíceis.</p>";document.getElementById('resultContent').innerHTML=report;document.getElementById('quiz').classList.add('hidden');document.getElementById('report').classList.remove('hidden')}function copyToClipboard(){navigator.clipboard.writeText(document.getElementById('resultContent').innerText);alert("Copiado!")}function sendEmail(){const body=encodeURIComponent(document.getElementById('resultContent').innerText);window.location.href=`mailto:mentor@edsonlima.com?subject=Relatório de Motivadores&body=${body}`}init()</script></body></html>
